---
interface Props {
  mediaPath: string;
}

const { mediaPath } = Astro.props;
---

<article class="tile spotify media-tile" id="media-tile">
  <div class="spotify-head">
    <h2>Featured Watch</h2>
    <span class="spotify-state" id="media-state">Loading</span>
  </div>
  <div class="spotify-body">
    <a
      class="spotify-art-link"
      data-media-link
      href="https://www.themoviedb.org/"
      target="_blank"
      rel="noreferrer"
      aria-label="Open on TMDB"
    >
      <img
        id="media-art"
        src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
        alt="Movie or show poster"
        loading="lazy"
        decoding="async"
      />
    </a>
    <div class="spotify-meta" aria-live="polite">
      <a
        class="spotify-title"
        id="media-title"
        data-media-link
        href="https://www.themoviedb.org/"
        target="_blank"
        rel="noreferrer"
      >
        Checking TMDB...
      </a>
      <p class="spotify-artists" id="media-subtitle">Fetching the selected title.</p>
    </div>
  </div>
  <span class="spotify-corner-link" aria-hidden="true">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d={mediaPath} fill="currentColor"></path>
    </svg>
  </span>
</article>
